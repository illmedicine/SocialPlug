# Get your Subscription ID from: Azure Portal → Subscriptions
# Or run: az account show --query id -o tsv

subscription_id     = ""
location            = "eastus"
ssh_public_key_path = "C:/Users/demar/.ssh/socialplug_key.pub"
firebase_bucket     = "livepay-petition.appspot.com"

# Base64-encode your Firebase service account JSON:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-credentials.json"))
#   Linux/Mac:  cat firebase-credentials.json | base64 -w0
firebase_credentials_b64 = ""
