{
  "name": "socialplug",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "build:android": "cross-env CAPACITOR=1 vite build",
    "android:init": "cap add android",
    "android:sync": "npm run build:android && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run android:sync && cap run android",
    "android:icons": "capacitor-assets generate --android --assetPath assets",
    "android:aab": "npm run android:sync && cd android && gradlew.bat bundleRelease --no-daemon",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleRelease --no-daemon"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "firebase": "^10.13.0",
    "lucide-react": "^0.441.0",
    "date-fns": "^3.6.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@capacitor-firebase/authentication": "^6.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/assets": "^3.0.5",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2"
  }
}
